# =============================================================================
# IntelliServe IT Suite - Environment Configuration
# =============================================================================

# Database (PostgreSQL + TimescaleDB)
DB_HOST=postgres
DB_PORT=5432
DB_USER=intelliserve
DB_PASSWORD=CHANGE_ME
DB_NAME=intelliserve
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10

# Redis
REDIS_URL=redis://redis:6379/0
REDIS_CELERY_BROKER_URL=redis://redis:6379/1

# JWT Authentication
JWT_SECRET_KEY=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# =============================================================================
# LLM Provider Configuration
# =============================================================================
# Options: "dashscope" (Alibaba Cloud Bailian / OpenAI-compatible gateway) or "ollama" (local fallback)
LLM_PROVIDER=dashscope

# --- DashScope / Alibaba Cloud Bailian - Default ---
# Get API Key: https://dashscope.console.aliyun.com/apiKey
DASHSCOPE_API_KEY=sk-your-api-key-here
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_CHAT_MODEL=deepseek-v4-pro
DASHSCOPE_EMBED_MODEL=text-embedding-v4
DASHSCOPE_EMBED_DIMENSIONS=1024

# --- Ollama (Local) - Optional ---
# For full DeepSeek-V4 private deployment, prefer an OpenAI-compatible vLLM gateway
# and set DASHSCOPE_BASE_URL to the internal gateway URL.
# OLLAMA_BASE_URL=http://ollama:11434
# OLLAMA_CHAT_MODEL=deepseek-r1:32b
# OLLAMA_EMBED_MODEL=bge-m3
# OLLAMA_LIGHT_MODEL=deepseek-r1:8b

# Qdrant (Vector Database)
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=kb_chunks
QDRANT_VECTOR_SIZE=1024

# MinIO (Object Storage)
MINIO_ENDPOINT=minio:9000
MINIO_USER=minioadmin
MINIO_PASSWORD=CHANGE_ME
MINIO_BUCKET=intelliserve
MINIO_SECURE=false

# DingTalk Integration
DINGTALK_CLIENT_ID=
DINGTALK_CLIENT_SECRET=

# Application
APP_NAME=IntelliServe IT Suite
APP_ENV=development
LOG_LEVEL=INFO
LOG_FORMAT=json
TZ=Asia/Shanghai
